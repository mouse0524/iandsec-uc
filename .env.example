SECRET_KEY=replace-with-openssl-rand-hex-32
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PHONE=00000000000
INITIAL_ADMIN_PASSWORD=replace-with-strong-initial-password

MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_DATABASE=iandsec-user-center
MYSQL_USER=iandsec-user-center
MYSQL_PASSWORD=replace-with-strong-mysql-password

REDIS_PASSWORD=replace-with-strong-redis-password

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
SKILL_KNOW_SQL_SEARCH_ENABLED=0
EXTERNAL_URL_ALLOWED_HOSTS=api.openai.com

# NAS should be mounted into the app container, then configure the mounted path here.
DB_BACKUP_DIRECTORY=/opt/iandsec-uc/storage/db_backups
DB_BACKUP_RUN_AT=02:30
DB_BACKUP_RETENTION_DAYS=7
